{
  "name": "claude-leaderboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create claude-leaderboard-db",
    "db:migrate": "wrangler d1 execute claude-leaderboard-db --file=migrations/0001_initial.sql",
    "db:migrate:local": "wrangler d1 execute claude-leaderboard-db --local --file=migrations/0001_initial.sql",
    "db:seed": "wrangler d1 execute claude-leaderboard-db --file=migrations/0002_seed_invites.sql",
    "db:seed:local": "wrangler d1 execute claude-leaderboard-db --local --file=migrations/0002_seed_invites.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.65.0"
  }
}
